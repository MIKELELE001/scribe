# Copy to .env.local (Next.js runtime) and .env (Prisma CLI). Keep DATABASE_URL
# in sync across both. Never commit real secrets — this file is a template only.

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — PostgreSQL (Neon/Supabase) in production.
# DATABASE_URL: pooled connection string (used by the app at runtime).
# DIRECT_URL:   direct connection (used by `prisma db push` / migrations).
# Neon example (note ?pgbouncer=true on the pooled URL):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/scribe?sslmode=require&pgbouncer=true"
#   DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/scribe?sslmode=require"
DATABASE_URL=
DIRECT_URL=

# AI — server-side only, never exposed to the client.
GROQ_API_KEY=

# Payments
PAYMENT_MODE=mock                                 # "mock" | "real"
CIRCLE_API_KEY=
CIRCLE_BASE_URL=https://api-sandbox.circle.com
ARC_RPC_URL=
ARC_CHAIN_ID=
SCRIBE_TREASURY_WALLET=
SCRIBE_TREASURY_PRIVATE_KEY=
